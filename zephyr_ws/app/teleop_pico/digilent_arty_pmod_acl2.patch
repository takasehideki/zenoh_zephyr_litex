diff --git a/litex_boards/targets/digilent_arty.py b/litex_boards/targets/digilent_arty.py
index fedef148..4be4a31f 100755
--- a/litex_boards/targets/digilent_arty.py
+++ b/litex_boards/targets/digilent_arty.py
@@ -83,6 +83,7 @@ class BaseSoC(SoCCore):
         with_spi_flash  = False,
         with_buttons    = False,
         with_pmod_gpio  = False,
+        pmod_acl2       = None,
         with_can        = False,
         **kwargs):
         platform = digilent_arty.Platform(variant=variant, toolchain=toolchain)
@@ -183,6 +184,27 @@ class BaseSoC(SoCCore):
                 with_irq = self.irq.enabled
             )
 
+        # Pmod ACL2 on selected PMOD.
+        if pmod_acl2:
+            from litex.build.generic_platform import Subsignal, Pins, IOStandard
+
+            assert pmod_acl2 in ["pmoda", "pmodb", "pmodc", "pmodd"]
+            platform.add_extension([
+                ("pmod_acl2_spi", 0,
+                    Subsignal("cs_n", Pins(f"{pmod_acl2}:0")),
+                    Subsignal("mosi", Pins(f"{pmod_acl2}:1")),
+                    Subsignal("miso", Pins(f"{pmod_acl2}:2")),
+                    Subsignal("clk",  Pins(f"{pmod_acl2}:3")),
+                    IOStandard("LVCMOS33"),
+                ),
+            ])
+            self.add_spi_master(
+                name="spimaster",
+                pads=platform.request("pmod_acl2_spi"),
+                data_width=8,
+                spi_clk_freq=1e6,
+            )
+
         # CAN --------------------------------------------------------------------------------------
         if with_can:
             from litex.soc.cores.can.ctu_can_fd import CTUCANFD
@@ -215,6 +237,7 @@ def main():
 
     parser.add_target_argument("--with-spi-flash", action="store_true", help="Enable memory-mapped SPI flash.")
